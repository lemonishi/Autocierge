# Server
PORT=8080
# HITL classification confidence gate (0..1). Calibrated later via the eval harness (Plan 6).
CONFIDENCE_THRESHOLD=0.75
# PostgreSQL connection (local dev = Homebrew postgresql@16 on port 5433; prod = Alibaba Cloud RDS).
# Port 5433 because 5432 is held by another app's Docker Postgres on this machine.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/supportsentinel?sslmode=disable
# Tests use a separate database; leave unset to SKIP DB-backed tests.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/supportsentinel_test?sslmode=disable
# Qwen / Alibaba Cloud Model Studio (DashScope, OpenAI-compatible endpoint)
# Required for real classification; if unset the server uses the fake classifier.
DASHSCOPE_API_KEY=
# International (Singapore) endpoint by default; switch to
# https://dashscope.aliyuncs.com/compatible-mode/v1 for China (Beijing).
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# ---------------------------------------------------------------------------
# IMAP inbound-email ingestion (optional — leave IMAP_HOST blank to disable)
# ---------------------------------------------------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_SECONDS=30

# ---------------------------------------------------------------------------
# SMTP outbound-email alerting (optional — leave SMTP_HOST blank to disable)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# Escalation/ops address that receives alert emails; defaults to SMTP_FROM if unset.
SMTP_TO=

# ---------------------------------------------------------------------------
# Slack alerting (optional — leave SLACK_WEBHOOK_URL blank to disable)
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
